{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://owl.dev/schemas/step_invocation/v1.json",
  "title": "StepInvocation",
  "description": "Machine-readable instruction given to a skill before it starts executing a workflow step.",
  "type": "object",
  "required": ["schema_version", "task", "step", "inputs", "outputs"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": 1 },
    "task": {
      "type": "object",
      "required": ["id", "title", "kind", "workflow_key", "parent_id", "children"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string" },
        "kind": { "type": "string", "enum": ["task", "composite_task"] },
        "workflow_key": { "type": "string", "minLength": 1 },
        "parent_id": { "type": ["string", "null"] },
        "children": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "step": {
      "type": "object",
      "required": ["id", "status", "requires", "creates", "uses_if_present"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": ["string", "null"] },
        "skill": { "type": ["string", "null"] },
        "status": { "const": "ready" },
        "requires": { "type": "array", "items": { "type": "string" } },
        "creates": { "type": "array", "items": { "type": "string" } },
        "uses_if_present": { "type": "array", "items": { "type": "string" } }
      }
    },
    "inputs": {
      "type": "object",
      "required": ["artifacts"],
      "additionalProperties": false,
      "properties": {
        "artifacts": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/artifact_descriptor" }
        }
      }
    },
    "outputs": {
      "type": "object",
      "required": ["artifacts"],
      "additionalProperties": false,
      "properties": {
        "artifacts": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/artifact_descriptor" }
        }
      }
    }
  },
  "$defs": {
    "artifact_descriptor": {
      "oneOf": [
        { "$ref": "#/$defs/artifact_resolved" },
        { "$ref": "#/$defs/artifact_unresolved" }
      ]
    },
    "artifact_resolved": {
      "type": "object",
      "required": [
        "key", "type", "task_id", "workflow_key",
        "storage_role", "storage_path_template",
        "path", "uri", "exists",
        "multiple", "optional",
        "template_uri", "template_path", "template_present",
        "validation", "front_matter", "agent_hints"
      ],
      "properties": {
        "key": { "type": "string" },
        "type": { "type": "string" },
        "task_id": { "type": "string" },
        "workflow_key": { "type": "string" },
        "storage_role": { "type": "string" },
        "storage_path_template": { "type": "string" },
        "path": { "type": "string" },
        "uri": { "type": "string" },
        "exists": { "type": "boolean" },
        "multiple": { "type": "boolean" },
        "optional": { "type": "boolean" },
        "template_uri": { "type": ["string", "null"] },
        "template_path": { "type": ["string", "null"] },
        "template_present": { "type": "boolean" },
        "validation": { "type": "object" },
        "front_matter": { "type": "object" },
        "agent_hints": { "type": "object" },
        "title": { "type": ["string", "null"] }
      }
    },
    "artifact_unresolved": {
      "type": "object",
      "required": ["key", "unresolved", "error"],
      "additionalProperties": false,
      "properties": {
        "key": { "type": "string" },
        "unresolved": { "const": true },
        "error": {
          "type": "object",
          "required": ["code", "message", "details"],
          "properties": {
            "code": { "type": "string" },
            "message": { "type": "string" },
            "details": { "type": "object" }
          }
        }
      }
    }
  }
}
