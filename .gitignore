# Claude Code local-only settings
.claude/settings.local.json
.claude/**/*.local.*

# Claude Code local memory / session store (per-user agent state, not shared)
.claude/projects/

# Claude Code review lock/state (per-clone transient, not shared)
.claude/reviews/

# Ruby / bundler
.bundle/
vendor/bundle/
tmp/

# Built gems
*.gem

# Test coverage
coverage/

# Owl local state (per-clone pointer files, not shared)
.owl/local/

# Owl upgrade/init pre-write backups (transient, per-clone)
.owl/.backup/

# Owl atomic-archive staging (per-transaction work dirs; transient)
tasks/.archive-staging/
